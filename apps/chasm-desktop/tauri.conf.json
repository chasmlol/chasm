{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "chasm",
  "version": "0.1.0",
  "identifier": "com.chasm.app",
  "build": {
    "frontendDist": "./dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "chasm",
        "url": "index.html",
        "width": 1280,
        "height": 860,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": []
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "../../static": "static",
      "../../scripts": "scripts",
      "../../tools": "tools",
      "../../crates/chasm-web/ui/dist": "crates/chasm-web/ui/dist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
